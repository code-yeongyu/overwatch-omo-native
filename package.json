{
  "name": "overwatch-omo-native",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Browser-based Overwatch-style Practice Range with Soldier: 76, built with TypeScript 7, Three.js, and Biome.",
  "scripts": {
    "dev": "vite",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "typecheck:test": "tsgo --noEmit -p tsconfig.test.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@types/three": "latest",
    "typescript": "^7.0.0-beta",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "three": "^0.175.0"
  }
}
